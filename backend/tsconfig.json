{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": [
    "config/**/*",
    "models/**/*",
    "scripts/**/*",
    "services/**/*",
    "server.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
